---
interface Props {
  title: string;
  headline: string;
  subtitle: string;
  pdfUrl: string;
  valueProps: string[];
  ctaText: string;
  previewDescription: string;
  pages: number;
  type: string;
}

const { title, headline, subtitle, pdfUrl, valueProps, ctaText, previewDescription, pages, type } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={previewDescription} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={previewDescription} />
    <meta property="og:type" content="website" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #1f2937;
        background: #ffffff;
        line-height: 1.6;
      }
      .hero {
        max-width: 720px;
        margin: 0 auto;
        padding: 64px 24px;
        text-align: center;
      }
      .badge {
        display: inline-block;
        background: #eff6ff;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 6px 16px;
        border-radius: 99px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 24px;
      }
      h1 {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 16px;
        color: #111827;
      }
      .subtitle {
        font-size: 1.15rem;
        color: #6b7280;
        margin-bottom: 40px;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
      }
      .value-props {
        text-align: left;
        max-width: 480px;
        margin: 0 auto 40px;
      }
      .value-props li {
        list-style: none;
        padding: 10px 0;
        font-size: 1.05rem;
        display: flex;
        align-items: flex-start;
        gap: 12px;
      }
      .value-props li::before {
        content: '✓';
        color: #2563eb;
        font-weight: 700;
        flex-shrink: 0;
        margin-top: 1px;
      }
      .cta-section {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 32px;
        max-width: 480px;
        margin: 0 auto 48px;
      }
      .cta-section h2 {
        font-size: 1.2rem;
        margin-bottom: 16px;
      }
      .form-group {
        margin-bottom: 12px;
      }
      .form-group input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
      }
      .form-group input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
      }
      .cta-button {
        display: block;
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 1.05rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
      }
      .cta-button:hover {
        background: #1d4ed8;
      }
      .meta {
        font-size: 0.85rem;
        color: #9ca3af;
        margin-top: 12px;
      }
      .body-content {
        max-width: 640px;
        margin: 0 auto;
        padding: 0 24px 64px;
        font-size: 1.05rem;
        color: #374151;
      }
      .body-content h2 {
        font-size: 1.4rem;
        margin: 32px 0 12px;
        color: #111827;
      }
      .body-content p {
        margin-bottom: 16px;
      }
      .body-content strong {
        color: #1f2937;
      }
      @media (max-width: 600px) {
        h1 { font-size: 1.8rem; }
        .hero { padding: 40px 20px; }
      }
    </style>
  </head>
  <body>
    <div class="hero">
      <span class="badge">{type} · {pages} pages</span>
      <h1>{headline}</h1>
      <p class="subtitle">{subtitle}</p>

      <ul class="value-props">
        {valueProps.map((prop) => <li>{prop}</li>)}
      </ul>

      <div class="cta-section">
        <h2>Get your free copy</h2>
        <form id="lead-form">
          <div class="form-group">
            <input type="text" name="name" placeholder="Your first name" required />
          </div>
          <div class="form-group">
            <input type="email" name="email" placeholder="Your email address" required />
          </div>
          <button type="submit" class="cta-button">{ctaText}</button>
        </form>
        <p class="meta">Free download · No spam · Unsubscribe anytime</p>
      </div>
    </div>

    <div class="body-content">
      <slot />
    </div>

    <script define:vars={{ pdfUrl }}>
      document.getElementById('lead-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const name = form.name.value;
        const email = form.email.value;
        const button = form.querySelector('button');

        button.textContent = 'Sending...';
        button.disabled = true;

        try {
          // Send lead to Notion (via API route if configured)
          const res = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, resource: document.title, url: window.location.href }),
          });

          // Redirect to PDF regardless
          window.location.href = pdfUrl;
        } catch {
          // Still deliver the PDF even if lead capture fails
          window.location.href = pdfUrl;
        }
      });
    </script>
  </body>
</html>
